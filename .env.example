# The local path on your Windows host where scans arrive (e.g. your OneDrive folder)
HOST_SCAN_DIR=C:\Users\marko\OneDrive\Documents\Scans

# The base directory where your scans arrive. E.g. /app/scans inside Docker
SCAN_DIRECTORY=/app/scans

# URL to Ollama running on the host machine. 
# host.docker.internal resolves to the host machine from inside Docker.
APP_OLLAMA_HOST=http://host.docker.internal:11434

# Text Model choice - used for PDFs and clear text JPEGs
OLLAMA_TEXT_MODEL=ministral-3:14b

# Vision Model choice - used when OCR fails to detect text on JPEGs (e.g. photos)
OLLAMA_VISION_MODEL=llama3.2-vision

# Number of seconds to wait to ensure a newly created file has finished writing
FILE_READY_WAIT_SECONDS=5
